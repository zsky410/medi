# ==== Backend (apps/api) ====
DATABASE_URL="postgresql://medi:medi@localhost:5433/medi?schema=public"
REDIS_URL="redis://localhost:6380"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Google OAuth (optional - leave empty to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/auth/google/callback"

# App URLs
API_PORT=4000
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3002"

# Billing: leave STRIPE_SECRET_KEY empty to use the dev mock provider
STRIPE_SECRET_KEY=""
STRIPE_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""

# Geocoding provider: nominatim (free) or goong (Vietnam-optimized, needs key)
GEO_PROVIDER="nominatim"
GOONG_API_KEY=""

# Affiliate partner IDs (leave empty for non-affiliate fallback links in dev)
AFFILIATE_BOOKING_AID=""
AFFILIATE_AGODA_CID=""
AFFILIATE_VIATOR_PID=""
AFFILIATE_KLOOK_AID=""
AFFILIATE_TRAVELOKA_AID=""

# AI: leave OPENAI_API_KEY empty to use mock provider (template-based)
AI_PROVIDER="mock"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Booking import webhook secret (for POST /import/inbound-email)
IMPORT_EMAIL_SECRET="change-me-import-secret"

# ==== Frontend (apps/web) ====
# Browser calls same-origin /api (proxied to API_URL via next.config rewrites).
NEXT_PUBLIC_API_URL="/api"
NEXT_PUBLIC_DIRECT_API_URL="http://localhost:4000"
NEXT_PUBLIC_PROVINCES_API_URL="https://provinces.open-api.vn/api/v2"
